{
  "name": "9router-usage-monitor",
  "version": "1.0.0",
  "description": "9router 用量监控 — 爬取 Dashboard 中的大模型用量数据",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "naive-ui": "^2.41.0",
    "pinia": "^3.0.2",
    "playwright": "^1.60.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "~5.7.3",
    "unocss": "^66.0.0",
    "vite": "^6.3.2"
  },
  "build": {
    "appId": "com.9router.usage-monitor",
    "productName": "9router-usage-monitor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      }
    ],
    "asar": true,
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    }
  }
}
